# --- Database -------------------------------------------------------------
# Dev: local SQLite. Prod (Vercel): a Postgres URL (Neon/Supabase) + switch
# prisma/schema.prisma provider to "postgresql".
DATABASE_URL="file:./dev.db"

# --- n8n instance (read-only REST API) ------------------------------------
# Without these, the app runs on bundled demo fixtures.
N8N_BASE_URL="https://your-instance.app.n8n.cloud"
N8N_API_KEY=""

# --- OpenAI (AI enrichment) -----------------------------------------------
# Without this, summaries/runbooks fall back to heuristics.
OPENAI_API_KEY=""
# Optional model override (default: gpt-4.1)
OPENAI_MODEL="gpt-4.1"

# --- Slack app ------------------------------------------------------------
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""
# Optional: pin the master channel; otherwise resolved by name #n8n-backoffice
SLACK_MASTER_CHANNEL_ID=""

# Public base URL (used for Slack OAuth redirect + interactivity in prod)
APP_BASE_URL="http://localhost:3000"
