# --- Database (Postgres) --------------------------------------------------
# Supabase/Neon connection string. Get it from the Supabase dashboard:
# Project → Connect → ORMs/Prisma → copy the URI (with your DB password).
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.<ref>.supabase.co:5432/postgres"

# --- n8n instance (read-only REST API) ------------------------------------
# Without these, the app runs on bundled demo fixtures.
N8N_BASE_URL="https://your-instance.app.n8n.cloud"
N8N_API_KEY=""

# --- OpenAI (AI enrichment) -----------------------------------------------
# Without this, summaries/runbooks fall back to heuristics.
OPENAI_API_KEY=""
# Optional model override (default: gpt-4.1)
OPENAI_MODEL="gpt-4.1"

# --- Otto (Slack coworker) ------------------------------------------------
# Otto answers @mentions over your estate + files Linear tickets. Uses
# OPENAI_API_KEY above. Optional model override just for Otto:
OTTO_MODEL=""
# Linear real API (NOT the Claude MCP) — enables "Create Linear ticket".
LINEAR_API_KEY=""
LINEAR_TEAM_ID=""

# --- Slack app ------------------------------------------------------------
SLACK_CLIENT_ID=""
SLACK_CLIENT_SECRET=""
SLACK_SIGNING_SECRET=""
# Optional: pin the master channel; otherwise resolved by name #n8n-backoffice
SLACK_MASTER_CHANNEL_ID=""

# Public base URL (used for Slack OAuth redirect + interactivity in prod)
APP_BASE_URL="http://localhost:3000"
